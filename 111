<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0">
<title>电击弹跳</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; touch-action:none; }
  body {
    background: #f4f0e8;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    overflow: hidden;
    font-family: 'Georgia', serif;
    user-select: none;
  }
  #ui {
    position: fixed;
    top: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
    background: rgba(244,240,232,0.92);
    border-bottom: 2px solid #333;
    z-index: 10;
  }
  .ui-item {
    color: #222;
    font-size: 13px;
    font-family: 'Georgia', serif;
    letter-spacing: 0.5px;
  }
  .ui-val {
    font-weight: bold;
    font-size: 15px;
    color: #111;
  }
  #canvas { display:block; touch-action:none; }
  #overlay {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(244,240,232,0.95);
    z-index: 20;
  }
  #overlay h1 {
    font-size: 28px;
    color: #111;
    margin-bottom: 10px;
    letter-spacing: 3px;
    font-family: 'Georgia', serif;
    font-style: italic;
    border-bottom: 2px solid #333;
    padding-bottom: 8px;
  }
  #overlay .sub {
    color: #444;
    font-size: 13px;
    margin-bottom: 22px;
    text-align: center;
    line-height: 2;
    padding: 0 24px;
    font-family: 'Georgia', serif;
  }
  #overlay .score-display {
    color: #111;
    font-size: 42px;
    font-weight: bold;
    font-family: 'Georgia', serif;
    margin: 6px 0 2px;
    font-style: italic;
  }
  #overlay .score-label {
    color: #555;
    font-size: 12px;
    margin-bottom: 24px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .btn {
    padding: 10px 32px;
    border: 2px solid #333;
    background: transparent;
    color: #111;
    font-size: 15px;
    font-family: 'Georgia', serif;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.15s;
    margin: 5px;
    font-style: italic;
  }
  .btn:hover, .btn:active {
    background: #333;
    color: #f4f0e8;
  }
  .level-info {
    color: #555;
    font-size: 12px;
    margin-bottom: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  #hint {
    position: fixed;
    bottom: 12px;
    left: 0; right: 0;
    text-align: center;
    color: #666;
    font-size: 12px;
    letter-spacing: 0.5px;
    z-index: 5;
    pointer-events: none;
    font-family: 'Georgia', serif;
    font-style: italic;
  }
  .stars { font-size: 26px; margin: 6px 0 16px; }
  #toast {
    position:fixed;top:55px;left:50%;transform:translateX(-50%);
    background:rgba(40,40,40,0.88);color:#f4f0e8;border:1px solid #555;
    padding:7px 18px;font-size:12px;z-index:50;pointer-events:none;
    font-family:'Georgia',serif;font-style:italic;transition:opacity 0.3s;
  }
</style>
</head>
<body>
<div id="ui">
  <div class="ui-item">得分 <span class="ui-val" id="scoreVal">0</span></div>
  <div class="ui-item">第 <span class="ui-val" id="levelVal">1</span> 关</div>
  <div class="ui-item">磁铁剩余 <span class="ui-val" id="ballsVal">3</span></div>
</div>
<canvas id="canvas"></canvas>
<div id="hint">点击放置磁铁 · 放置完毕后按【开始坠落】</div>
<div id="overlay">
  <h1>⚡ 电击弹跳</h1>
  <div class="sub">放置带电磁铁，让人物从高空坠落<br>弹跳次数越多，电击得分越高！</div>
  <div class="level-info" id="levelLabel">第 1 关 · 可放置 3 个磁铁</div>
  <button class="btn" onclick="startLevel()">▶ 开始游戏</button>
</div>

<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');

// roundRect polyfill for older mobile browsers
if (!CanvasRenderingContext2D.prototype.roundRect) {
  CanvasRenderingContext2D.prototype.roundRect = function(x, y, w, h, r) {
    r = Math.min(r||0, Math.abs(w)/2, Math.abs(h)/2);
    this.beginPath();
    this.moveTo(x + r, y);
    this.lineTo(x + w - r, y);
    this.quadraticCurveTo(x + w, y, x + w, y + r);
    this.lineTo(x + w, y + h - r);
    this.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    this.lineTo(x + r, y + h);
    this.quadraticCurveTo(x, y + h, x, y + h - r);
    this.lineTo(x, y + r);
    this.quadraticCurveTo(x, y, x + r, y);
    this.closePath();
    return this;
  };
}

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// ── 关卡 ─────────────────────────────────────────────────
const LEVELS = [
  { id:1, balls:3, gravMul:1.0, label:'新手上路',  starScore:[400,900,1800]   },
  { id:2, balls:4, gravMul:1.1, label:'电流飞舞',  starScore:[700,1600,3200]  },
  { id:3, balls:5, gravMul:1.2, label:'高压惊魂',  starScore:[1100,2400,4800] },
  { id:4, balls:6, gravMul:1.3, label:'雷霆万钧',  starScore:[1800,3800,7000] },
  { id:5, balls:7, gravMul:1.4, label:'极限电击',  starScore:[2800,5500,9500] },
];
let currentLevel = 0;
let levelCfg = LEVELS[0];

// ── 状态 ─────────────────────────────────────────────────
let phase = 'menu';
let magnets = [];
let npc = null;
let score = 0;
let bounceCount = 0;
let sparks = [];
let shockWaves = [];
let tick = 0;
let ghostPos = null;
let animFrame;

const MAG_R = 16;         // magnet radius (smaller)
const NPC_H = 54;         // npc height reference
const GRAVITY = 0.32;
const BOUNCE = 0.72;
const SHOCK_BASE = 70;

// ── NPC ─────────────────────────────────────────────────
function createNPC() {
  return {
    x: canvas.width / 2 + (Math.random()-0.5)*50,
    y: 65,
    vx: (Math.random()-0.5)*1.5,
    vy: 0,
    rot: 0,
    rotV: 0,
    shocked: 0,
    alive: true,
    trail: [],
    // limb angles for ragdoll feel
    lArmAng: -0.3, rArmAng: 0.3,
    lLegAng: 0.1,  rLegAng: -0.1,
  };
}

// ── Sketch helpers ────────────────────────────────────────
// Slightly wobbly line for sketch feel
function sketchLine(x1,y1,x2,y2,wobble=1.5) {
  ctx.beginPath();
  const mx = (x1+x2)/2 + (Math.random()-0.5)*wobble;
  const my = (y1+y2)/2 + (Math.random()-0.5)*wobble;
  ctx.moveTo(x1+(Math.random()-0.5)*0.5, y1+(Math.random()-0.5)*0.5);
  ctx.quadraticCurveTo(mx,my, x2+(Math.random()-0.5)*0.5, y2+(Math.random()-0.5)*0.5);
  ctx.stroke();
}

function sketchCircle(cx,cy,r,wobble=1.5) {
  ctx.beginPath();
  const steps = 28;
  for (let i=0;i<=steps;i++) {
    const a = (i/steps)*Math.PI*2;
    const rr = r + (Math.random()-0.5)*wobble;
    const x = cx + Math.cos(a)*rr;
    const y = cy + Math.sin(a)*rr;
    i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
  }
  ctx.closePath();
}

function sketchArc(cx,cy,r,a1,a2,wobble=1.2) {
  ctx.beginPath();
  const steps = 14;
  for (let i=0;i<=steps;i++) {
    const a = a1 + (i/steps)*(a2-a1);
    const rr = r + (Math.random()-0.5)*wobble;
    const x = cx + Math.cos(a)*rr;
    const y = cy + Math.sin(a)*rr;
    i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
  }
  ctx.stroke();
}

// Hatch fill for sketch shading
function hatchRect(x,y,w,h,gap=5,ang=0.6) {
  ctx.save();
  ctx.beginPath();
  ctx.rect(x,y,w,h);
  ctx.clip();
  ctx.strokeStyle = 'rgba(0,0,0,0.12)';
  ctx.lineWidth = 0.7;
  const len = w+h;
  for (let d=-len; d<len; d+=gap) {
    ctx.beginPath();
    ctx.moveTo(x+d, y);
    ctx.lineTo(x+d+h/Math.tan(ang), y+h);
    ctx.stroke();
  }
  ctx.restore();
}

// ── Draw NPC (sketch realistic human) ────────────────────
function drawNPC(p) {
  const { x, y, rot, shocked } = p;
  const s = shocked > 0;

  ctx.save();
  ctx.translate(x, y);
  ctx.rotate(rot);

  const inkColor = s ? 'rgba(20,80,180,0.9)' : 'rgba(20,20,20,0.88)';
  const skinFill = s ? 'rgba(180,220,255,0.6)' : 'rgba(235,210,185,0.75)';
  const clothFill = s ? 'rgba(160,200,255,0.5)' : 'rgba(190,190,195,0.55)';
  const darkFill = s ? 'rgba(100,140,220,0.5)' : 'rgba(80,80,90,0.55)';
  const hairFill = s ? 'rgba(60,100,200,0.8)' : 'rgba(40,30,25,0.85)';

  ctx.lineJoin = 'round';
  ctx.lineCap = 'round';

  // ── LEGS (behind torso) ──
  const lLegA = p.lLegAng + (s ? (Math.random()-0.5)*0.5 : 0);
  const rLegA = p.rLegAng + (s ? (Math.random()-0.5)*0.5 : 0);

  // Thigh + shin + foot
  function drawLeg(side, ang) {
    const ox = side * 5;
    ctx.save();
    ctx.translate(ox, 14);
    ctx.rotate(ang);
    // thigh
    ctx.fillStyle = darkFill;
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 1.1;
    ctx.beginPath();
    ctx.roundRect(-4, 0, 8, 16, 2);
    ctx.fill();
    hatchRect(-4, 0, 8, 16, 4);
    ctx.stroke();
    // knee cap
    ctx.save();
    ctx.translate(0, 17);
    ctx.fillStyle = skinFill;
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 1;
    sketchCircle(0, 0, 4, 1);
    ctx.fill(); ctx.stroke();
    // shin
    ctx.translate(side*1.5, 2);
    ctx.rotate(ang * 0.4);
    ctx.fillStyle = darkFill;
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 1.1;
    ctx.beginPath();
    ctx.roundRect(-3.5, 0, 7, 14, 2);
    ctx.fill();
    ctx.stroke();
    // foot/shoe
    ctx.translate(0, 15);
    ctx.fillStyle = 'rgba(50,40,35,0.85)';
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.ellipse(side*2, 2, 7, 4, 0, 0, Math.PI*2);
    ctx.fill(); ctx.stroke();
    ctx.restore();
    ctx.restore();
  }

  drawLeg(-1, lLegA);
  drawLeg( 1, rLegA);

  // ── TORSO ──
  const torsoW = 14, torsoH = 22;
  ctx.fillStyle = clothFill;
  ctx.strokeStyle = inkColor;
  ctx.lineWidth = 1.3;
  ctx.beginPath();
  ctx.roundRect(-torsoW/2, -8, torsoW, torsoH, 3);
  ctx.fill();
  hatchRect(-torsoW/2, -8, torsoW, torsoH, 5, 0.7);
  ctx.stroke();
  // collar V
  ctx.strokeStyle = inkColor;
  ctx.lineWidth = 0.8;
  sketchLine(-3,-8, 0,-3, 0.5);
  sketchLine( 3,-8, 0,-3, 0.5);
  // waistband
  ctx.strokeStyle = 'rgba(0,0,0,0.3)';
  ctx.lineWidth = 1.5;
  sketchLine(-torsoW/2, 12, torsoW/2, 12, 0.8);

  // ── ARMS ──
  const lArmA = p.lArmAng + (s ? (Math.random()-0.5)*0.7 : Math.sin(tick*0.05)*0.15);
  const rArmA = p.rArmAng + (s ? (Math.random()-0.5)*0.7 : -Math.sin(tick*0.05)*0.15);

  function drawArm(side, ang) {
    ctx.save();
    ctx.translate(side * (torsoW/2), -4);
    ctx.rotate(ang);
    // upper arm
    ctx.fillStyle = clothFill;
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 1.1;
    ctx.beginPath();
    ctx.roundRect(-3.5, 0, 7, 14, 2);
    ctx.fill();
    hatchRect(-3.5, 0, 7, 14, 5);
    ctx.stroke();
    // elbow
    ctx.translate(side*1, 14);
    // forearm, slight angle
    ctx.rotate(ang * 0.5 + side*0.2);
    ctx.fillStyle = skinFill;
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.roundRect(-3, 0, 6, 12, 2);
    ctx.fill(); ctx.stroke();
    // hand
    ctx.translate(0, 13);
    ctx.fillStyle = skinFill;
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 0.9;
    sketchCircle(0, 0, 4.5, 1);
    ctx.fill(); ctx.stroke();
    // fingers (3 lines)
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 0.7;
    for (let f=-1;f<=1;f++) {
      sketchLine(f*1.5, -4, f*2, -8, 0.5);
    }
    ctx.restore();
  }

  drawArm(-1, lArmA);
  drawArm( 1, rArmA);

  // ── NECK ──
  ctx.fillStyle = skinFill;
  ctx.strokeStyle = inkColor;
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.roundRect(-4, -17, 8, 10, 2);
  ctx.fill(); ctx.stroke();

  // ── HEAD ──
  // skull shape (slightly oval)
  ctx.fillStyle = skinFill;
  ctx.strokeStyle = inkColor;
  ctx.lineWidth = 1.4;
  ctx.save();
  ctx.translate(0, -28);
  ctx.scale(1, 1.12);
  sketchCircle(0, 0, 11, 1.2);
  ctx.fill();
  ctx.stroke();
  ctx.restore();

  // jaw/chin — slightly squarish
  ctx.fillStyle = skinFill;
  ctx.strokeStyle = inkColor;
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(-8, -23);
  ctx.lineTo(-9, -16);
  ctx.quadraticCurveTo(-1, -12, 0, -12);
  ctx.quadraticCurveTo(1, -12, 9, -16);
  ctx.lineTo(8, -23);
  ctx.fill(); ctx.stroke();

  // ears
  for (const ex of [-11, 11]) {
    ctx.fillStyle = skinFill;
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 0.8;
    ctx.beginPath();
    ctx.ellipse(ex, -25, 3.5, 5, ex>0?0.3:-0.3, 0, Math.PI*2);
    ctx.fill(); ctx.stroke();
  }

  // hair (sketchy strokes)
  ctx.fillStyle = hairFill;
  ctx.strokeStyle = hairFill;
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(-11, -28);
  ctx.quadraticCurveTo(-10,-40, 0,-39);
  ctx.quadraticCurveTo(10,-40, 11,-28);
  ctx.quadraticCurveTo(8,-26, 0,-26);
  ctx.quadraticCurveTo(-8,-26, -11,-28);
  ctx.fill();
  // hair texture lines
  ctx.strokeStyle = s ? 'rgba(100,150,255,0.6)' : 'rgba(20,15,10,0.5)';
  ctx.lineWidth = 0.8;
  for (let h=-8;h<=8;h+=4) {
    sketchLine(h,-38, h*0.7,-27, 0.8);
  }

  // eyebrows
  ctx.strokeStyle = hairFill;
  ctx.lineWidth = 1.5;
  sketchLine(-8,-31, -4,-30, 0.5);
  sketchLine( 4,-30,  8,-31, 0.5);

  // eyes (realistic-ish sketch)
  const eyeY = -27;
  for (const ex of [-5.5, 5.5]) {
    // eye white
    ctx.fillStyle = s ? 'rgba(200,230,255,0.9)' : 'rgba(255,255,250,0.95)';
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 0.9;
    ctx.beginPath();
    ctx.ellipse(ex, eyeY, 4, 3, 0, 0, Math.PI*2);
    ctx.fill(); ctx.stroke();
    // iris
    ctx.fillStyle = s ? 'rgba(80,150,255,0.9)' : 'rgba(60,85,120,0.85)';
    ctx.beginPath();
    ctx.arc(ex, eyeY, 2.2, 0, Math.PI*2);
    ctx.fill();
    // pupil
    ctx.fillStyle = s ? '#fff' : '#111';
    ctx.beginPath();
    ctx.arc(ex + (s?0:0.4), eyeY, s?1.4:1.1, 0, Math.PI*2);
    ctx.fill();
    // eyelid line
    ctx.strokeStyle = inkColor;
    ctx.lineWidth = 1;
    sketchLine(ex-4, eyeY-1, ex+4, eyeY-1, 0.4);
  }

  // nose
  ctx.strokeStyle = inkColor;
  ctx.lineWidth = 0.9;
  sketchLine(0,-24, -1,-19, 0.6);
  sketchLine(-1,-19, 1,-19, 0.5);
  ctx.beginPath(); ctx.arc(-2.5,-19, 1.2, Math.PI, 0); ctx.stroke();
  ctx.beginPath(); ctx.arc( 2.5,-19, 1.2, Math.PI, 0); ctx.stroke();

  // mouth
  const mouthY = -15;
  ctx.strokeStyle = inkColor;
  ctx.lineWidth = 1;
  if (s) {
    // open mouth screaming
    ctx.fillStyle = 'rgba(80,30,30,0.8)';
    ctx.beginPath();
    ctx.ellipse(0, mouthY, 4, 3.5, 0, 0, Math.PI*2);
    ctx.fill(); ctx.stroke();
  } else {
    sketchLine(-4, mouthY, 4, mouthY, 0.5);
    ctx.strokeStyle = 'rgba(180,100,100,0.5)';
    ctx.lineWidth = 0.8;
    sketchArc(0, mouthY-1, 3, 0.3, Math.PI-0.3, 0.4);
  }

  // philtrum (nose-lip)
  ctx.strokeStyle = 'rgba(0,0,0,0.2)';
  ctx.lineWidth = 0.7;
  sketchLine(0,-18, 0,-16, 0.3);

  // ── SHOCK SPARKS on body ──
  if (s) {
    ctx.strokeStyle = 'rgba(80,150,255,0.8)';
    ctx.lineWidth = 1.2;
    for (let i=0;i<5;i++) {
      const sx = (Math.random()-0.5)*22;
      const sy = (Math.random()-0.5)*40 - 5;
      ctx.beginPath();
      ctx.moveTo(sx, sy);
      ctx.lineTo(sx+(Math.random()-0.5)*10, sy+(Math.random()-0.5)*10);
      ctx.stroke();
    }
    // blue aura
    ctx.strokeStyle = 'rgba(100,160,255,0.25)';
    ctx.lineWidth = 8;
    sketchCircle(0, -8, 26, 4);
    ctx.stroke();
  }

  ctx.restore();
}

// ── Draw Magnet (sketch black/gray, smaller) ─────────────
function drawMagnet(mag, isGhost) {
  const { x, y } = mag;
  const r = MAG_R;
  const alpha = isGhost ? 0.4 : 1;
  ctx.save();
  ctx.globalAlpha = alpha;

  // outer sketchy circle — dark grey
  ctx.fillStyle = 'rgba(50,50,55,0.82)';
  ctx.strokeStyle = '#1a1a1a';
  ctx.lineWidth = 1.5;
  sketchCircle(x, y, r, 1.5);
  ctx.fill();

  // hatch shading inside
  ctx.save();
  ctx.beginPath();
  ctx.arc(x, y, r-1, 0, Math.PI*2);
  ctx.clip();
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 0.8;
  for (let d=-r*2; d<r*2; d+=4) {
    ctx.beginPath();
    ctx.moveTo(x-r+d, y-r);
    ctx.lineTo(x-r+d+r, y+r);
    ctx.stroke();
  }
  ctx.restore();

  // inner ring
  ctx.strokeStyle = 'rgba(100,100,110,0.7)';
  ctx.lineWidth = 1;
  sketchCircle(x, y, r*0.62, 1.2);
  ctx.stroke();

  // highlight glint
  ctx.fillStyle = 'rgba(255,255,255,0.18)';
  ctx.beginPath();
  ctx.ellipse(x-r*0.25, y-r*0.28, r*0.25, r*0.16, -0.5, 0, Math.PI*2);
  ctx.fill();

  // outer stroke (second pass for sketch double-line feel)
  ctx.strokeStyle = 'rgba(10,10,10,0.6)';
  ctx.lineWidth = 1;
  sketchCircle(x, y, r, 2);
  ctx.stroke();

  // ── Electric sparks/arcs emanating ──
  if (!isGhost) {
    const arcCount = 4;
    for (let i=0; i<arcCount; i++) {
      const a1 = (tick*0.045 + (i/arcCount)*Math.PI*2) % (Math.PI*2);
      const a2 = a1 + 0.6 + Math.sin(tick*0.08+i)*0.3;
      const px1 = x + Math.cos(a1)*(r*0.7);
      const py1 = y + Math.sin(a1)*(r*0.7);
      const px2 = x + Math.cos(a2)*(r + 4 + Math.sin(tick*0.12+i)*3);
      const py2 = y + Math.sin(a2)*(r + 4 + Math.sin(tick*0.12+i)*3);
      ctx.save();
      ctx.strokeStyle = i%2===0 ? 'rgba(100,160,255,0.75)' : 'rgba(200,230,255,0.6)';
      ctx.lineWidth = 0.9 + Math.random()*0.5;
      ctx.globalAlpha = 0.55 + 0.45*Math.sin(tick*0.18+i*1.2);
      ctx.beginPath();
      ctx.moveTo(px1,py1);
      const mx = (px1+px2)/2 + (Math.random()-0.5)*6;
      const my = (py1+py2)/2 + (Math.random()-0.5)*6;
      ctx.quadraticCurveTo(mx,my, px2,py2);
      ctx.stroke();
      ctx.restore();
    }

    // field rings (faint)
    for (let ri=1; ri<=2; ri++) {
      ctx.save();
      ctx.globalAlpha = (0.06 - ri*0.02) * (0.7+0.3*Math.sin(tick*0.06+ri));
      ctx.strokeStyle = '#6090ee';
      ctx.lineWidth = 1;
      sketchCircle(x, y, r + ri*8 + Math.sin(tick*0.07)*2, 2);
      ctx.stroke();
      ctx.restore();
    }
  }

  // N/S pole label
  ctx.fillStyle = isGhost ? 'rgba(80,80,80,0.5)' : 'rgba(200,210,255,0.85)';
  ctx.font = `bold ${Math.floor(r*0.55)}px Georgia`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('⚡', x, y);

  ctx.restore();
}

// ── Background (sketch paper) ─────────────────────────────
function drawBG() {
  const W = canvas.width, H = canvas.height;

  // paper tone
  ctx.fillStyle = '#f4f0e8';
  ctx.fillRect(0, 0, W, H);

  // subtle paper grain
  ctx.save();
  ctx.globalAlpha = 0.025;
  for (let i=0;i<600;i++) {
    ctx.fillStyle = Math.random()>0.5 ? '#000' : '#888';
    ctx.fillRect(Math.random()*W, Math.random()*H, 1, 1);
  }
  ctx.restore();

  // faint grid (like graph paper)
  ctx.save();
  ctx.strokeStyle = 'rgba(0,0,0,0.05)';
  ctx.lineWidth = 0.5;
  const gs = 40;
  for (let x=0;x<W;x+=gs) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
  for (let y=0;y<H;y+=gs) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
  ctx.restore();

  // left margin line
  ctx.save();
  ctx.strokeStyle = 'rgba(200,150,150,0.25)';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(40,0); ctx.lineTo(40,H); ctx.stroke();
  ctx.restore();

  // ground line (double sketch)
  const GY = H - 32;
  ctx.save();
  ctx.strokeStyle = 'rgba(30,30,30,0.7)';
  ctx.lineWidth = 2;
  sketchLine(0, GY, W, GY, 1.5);
  ctx.stroke();
  ctx.strokeStyle = 'rgba(30,30,30,0.2)';
  ctx.lineWidth = 1;
  sketchLine(0, GY+3, W, GY+3, 1.5);
  ctx.stroke();
  ctx.restore();

  // border frame
  ctx.save();
  ctx.strokeStyle = 'rgba(30,30,30,0.5)';
  ctx.lineWidth = 1.5;
  ctx.strokeRect(2, 32, W-4, H-34);
  ctx.restore();

  // altitude markers (dashed)
  ctx.save();
  ctx.setLineDash([6,8]);
  ctx.strokeStyle = 'rgba(0,0,0,0.07)';
  ctx.lineWidth = 0.8;
  const zones = [0.25, 0.5, 0.75];
  zones.forEach(z => {
    const zy = 32 + (H-64)*z;
    ctx.beginPath(); ctx.moveTo(42,zy); ctx.lineTo(W-4,zy); ctx.stroke();
    ctx.fillStyle = 'rgba(0,0,0,0.2)';
    ctx.font = '10px Georgia';
    ctx.textAlign = 'left';
    ctx.fillText(`${Math.floor((1-z)*100)}m`, 44, zy-3);
  });
  ctx.setLineDash([]);
  ctx.restore();
}

// ── Particles ─────────────────────────────────────────────
function spawnSparks(x, y) {
  for (let i=0;i<14;i++) {
    const a = Math.random()*Math.PI*2;
    const spd = Math.random()*4+1;
    sparks.push({
      x,y,
      vx:Math.cos(a)*spd, vy:Math.sin(a)*spd,
      life:1, decay:0.045+Math.random()*0.04,
      len: Math.random()*6+2,
      ang: a,
    });
  }
}

function spawnShockWave(x,y) {
  shockWaves.push({x,y,r:MAG_R,life:1});
}

// ── Physics ───────────────────────────────────────────────
function updatePhysics() {
  if (!npc || !npc.alive) return;
  const W = canvas.width, H = canvas.height;
  const GROUND = H - 32;

  npc.vy += GRAVITY * levelCfg.gravMul;
  npc.x  += npc.vx;
  npc.y  += npc.vy;
  npc.rot += npc.rotV;
  npc.rotV *= 0.96;
  if (npc.shocked>0) npc.shocked--;

  // limb flail when shocked
  if (npc.shocked>0) {
    npc.lArmAng = (Math.random()-0.5)*1.4;
    npc.rArmAng = (Math.random()-0.5)*1.4;
    npc.lLegAng = (Math.random()-0.5)*1.0;
    npc.rLegAng = (Math.random()-0.5)*1.0;
  } else {
    // natural fall pose
    const spd = Math.hypot(npc.vx, npc.vy);
    npc.lArmAng += (-0.6 - npc.lArmAng)*0.15;
    npc.rArmAng += (0.6  - npc.rArmAng)*0.15;
    npc.lLegAng += (0.3  - npc.lLegAng)*0.1;
    npc.rLegAng += (-0.3 - npc.rLegAng)*0.1;
  }

  // trail
  npc.trail.push({x:npc.x, y:npc.y});
  if (npc.trail.length>10) npc.trail.shift();

  // walls
  if (npc.x < 42)    { npc.x=42;       npc.vx=Math.abs(npc.vx)*0.75; }
  if (npc.x > W-4)   { npc.x=W-4;      npc.vx=-Math.abs(npc.vx)*0.75; }

  // ground
  if (npc.y + 28 >= GROUND) { npc.alive=false; endFall(); return; }

  // magnet collision
  for (const m of magnets) {
    const dx = npc.x - m.x;
    const dy = npc.y - m.y;
    const dist = Math.hypot(dx,dy);
    const minD = 18 + MAG_R;
    if (dist < minD && dist > 0.1) {
      const nx = dx/dist, ny = dy/dist;
      npc.x = m.x + nx*(minD+1);
      npc.y = m.y + ny*(minD+1);
      const dot = npc.vx*nx + npc.vy*ny;
      npc.vx = (npc.vx - 2*dot*nx) * BOUNCE;
      npc.vy = (npc.vy - 2*dot*ny) * BOUNCE;
      npc.rotV = npc.vx*0.08*(Math.random()>0.5?1:-1);
      bounceCount++;
      const dmg = Math.floor(SHOCK_BASE*(1+bounceCount*0.18));
      score += dmg;
      npc.shocked = 22;
      spawnSparks(npc.x, npc.y);
      spawnShockWave(m.x, m.y);
      m.hitTime = 12;
      const spd = Math.hypot(npc.vx,npc.vy);
      if (spd < 2.5) { npc.vx=nx*-4; npc.vy=ny*-5; }
      document.getElementById('scoreVal').textContent = score.toLocaleString();
      break;
    }
  }
}

// ── Main render ───────────────────────────────────────────
function render() {
  tick++;
  const W = canvas.width, H = canvas.height;

  drawBG();

  // magnet connections (faint field lines)
  if (magnets.length>=2) {
    for (let i=0;i<magnets.length;i++) {
      for (let j=i+1;j<magnets.length;j++) {
        const a=magnets[i], b=magnets[j];
        const d=Math.hypot(a.x-b.x,a.y-b.y);
        if (d>200) continue;
        ctx.save();
        ctx.globalAlpha=(1-d/200)*0.1*(0.5+0.5*Math.sin(tick*0.08+i+j));
        ctx.strokeStyle='#5080cc';
        ctx.lineWidth=0.8;
        ctx.setLineDash([4,6]);
        ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke();
        ctx.setLineDash([]);
        ctx.restore();
      }
    }
  }

  // magnets
  magnets.forEach(m => {
    drawMagnet(m, false);
    if (m.hitTime>0) {
      ctx.save();
      ctx.globalAlpha = m.hitTime/12*0.5;
      ctx.strokeStyle='#6090ff';
      ctx.lineWidth=2;
      sketchCircle(m.x,m.y,MAG_R+(12-m.hitTime)*3,2);
      ctx.stroke();
      ctx.restore();
      m.hitTime--;
    }
  });

  // ghost placement preview
  if (phase==='place' && ghostPos) {
    drawMagnet({x:ghostPos.x,y:ghostPos.y}, true);
  }

  // shock waves
  shockWaves = shockWaves.filter(s=>s.life>0);
  shockWaves.forEach(s => {
    ctx.save();
    ctx.globalAlpha = s.life*0.35;
    ctx.strokeStyle='#6090ee';
    ctx.lineWidth=1.2;
    sketchCircle(s.x, s.y, s.r+(1-s.life)*35, 2);
    ctx.stroke();
    ctx.restore();
    s.r += 1.5;
    s.life -= 0.07;
  });

  // NPC trail (pencil smear)
  if (npc && npc.trail.length>1) {
    for (let i=1;i<npc.trail.length;i++) {
      ctx.save();
      ctx.globalAlpha = (i/npc.trail.length)*0.12;
      ctx.strokeStyle='#334';
      ctx.lineWidth=1.5*(i/npc.trail.length);
      ctx.beginPath();
      ctx.moveTo(npc.trail[i-1].x,npc.trail[i-1].y);
      ctx.lineTo(npc.trail[i].x,npc.trail[i].y);
      ctx.stroke();
      ctx.restore();
    }
  }

  // NPC
  if (npc) {
    drawNPC(npc);
    if (npc.alive) updatePhysics();
  }

  // sparks (sketch-style: lines not dots)
  sparks = sparks.filter(s=>s.life>0);
  sparks.forEach(s => {
    ctx.save();
    ctx.globalAlpha = s.life*0.85;
    ctx.strokeStyle = s.life>0.5 ? '#5080ee' : '#99bbff';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(s.x, s.y);
    ctx.lineTo(s.x+Math.cos(s.ang)*s.len*s.life, s.y+Math.sin(s.ang)*s.len*s.life);
    ctx.stroke();
    ctx.restore();
    s.x+=s.vx; s.y+=s.vy; s.vy+=0.12; s.life-=s.decay;
  });

  // fall stats
  if (phase==='fall') {
    ctx.save();
    ctx.fillStyle='rgba(0,0,0,0.3)';
    ctx.font='italic 13px Georgia';
    ctx.textAlign='right';
    ctx.fillText(`弹跳 ×${bounceCount}`, W-14, 58);
    ctx.restore();
  }

  animFrame = requestAnimationFrame(render);
}

// ── Game flow ─────────────────────────────────────────────
function startLevel() {
  levelCfg = LEVELS[currentLevel];
  magnets=[]; sparks=[]; shockWaves=[]; npc=null;
  score=0; bounceCount=0;
  phase='place';
  document.getElementById('scoreVal').textContent='0';
  document.getElementById('levelVal').textContent=levelCfg.id;
  document.getElementById('ballsVal').textContent=levelCfg.balls;
  document.getElementById('hint').textContent=`点击放置磁铁 (剩余 ${levelCfg.balls} 个) · 放置完成后按【开始坠落】`;
  document.getElementById('overlay').style.display='none';

  let btn = document.getElementById('startFallBtn');
  if (!btn) {
    btn = document.createElement('button');
    btn.id='startFallBtn'; btn.className='btn';
    btn.style.cssText='position:fixed;bottom:52px;left:50%;transform:translateX(-50%);z-index:9;font-size:14px;padding:9px 28px;';
    btn.textContent='⚡ 开始坠落';
    btn.onclick=beginFall;
    document.body.appendChild(btn);
  }
  btn.style.display='block';
}

function beginFall() {
  if (magnets.length===0) { showToast('请先放置至少一个磁铁！'); return; }
  phase='fall';
  npc=createNPC();
  document.getElementById('hint').textContent='⚡ 小人坠落中！弹跳越多得分越高！';
  const btn=document.getElementById('startFallBtn');
  if(btn) btn.style.display='none';
  ghostPos=null;
}

function endFall() {
  phase='result';
  setTimeout(showResult, 700);
}

function showResult() {
  const cfg=LEVELS[currentLevel];
  const stars=score>=cfg.starScore[2]?3:score>=cfg.starScore[1]?2:score>=cfg.starScore[0]?1:0;
  const starStr='⭐'.repeat(stars)+'☆'.repeat(3-stars);
  const isLast=currentLevel===LEVELS.length-1;
  const ov=document.getElementById('overlay');
  ov.style.display='flex';
  ov.innerHTML=`
    <h1>结算</h1>
    <div class="level-info">第 ${cfg.id} 关 · ${cfg.label}</div>
    <div class="score-label">弹跳次数：${bounceCount} 次</div>
    <div class="score-display">${score.toLocaleString()}</div>
    <div class="score-label">得分</div>
    <div class="stars">${starStr}</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
      <button class="btn" onclick="retryLevel()">再来一次</button>
      ${!isLast&&stars>0?`<button class="btn" onclick="nextLevel()">下一关</button>`:''}
      ${isLast&&stars>0?`<button class="btn" onclick="resetGame()">重新开始</button>`:''}
    </div>
    ${stars===0?'<div style="color:#c33;font-size:12px;margin-top:10px;font-style:italic;">弹跳次数太少，多放几个磁铁试试！</div>':''}
  `;
}

function retryLevel(){ startLevel(); }
function nextLevel(){ currentLevel=Math.min(currentLevel+1,LEVELS.length-1); showMenu(); }
function resetGame(){ currentLevel=0; showMenu(); }

function showMenu() {
  const cfg=LEVELS[currentLevel];
  const ov=document.getElementById('overlay');
  ov.style.display='flex';
  ov.innerHTML=`
    <h1>⚡ 电击弹跳</h1>
    <div class="sub">放置带电磁铁，让人物从高空坠落<br>弹跳次数越多，电击得分越高！</div>
    <div class="level-info">第 ${cfg.id} 关 · ${cfg.label} · 可放置 ${cfg.balls} 个磁铁</div>
    <button class="btn" onclick="startLevel()">▶ 开始游戏</button>
  `;
  phase='menu';
  const btn=document.getElementById('startFallBtn');
  if(btn) btn.style.display='none';
}

// ── Input ─────────────────────────────────────────────────
function getPos(e) {
  const rect=canvas.getBoundingClientRect();
  const t=e.touches?e.touches[0]:e;
  return {x:t.clientX-rect.left, y:t.clientY-rect.top};
}

canvas.addEventListener('touchstart', onTap, {passive:false});
canvas.addEventListener('mousedown', onTap);
canvas.addEventListener('touchmove', onMove, {passive:false});
canvas.addEventListener('mousemove', onMove);
canvas.addEventListener('touchend', ()=>{ghostPos=null;});

function onMove(e) {
  if (phase!=='place') return;
  e.preventDefault&&e.preventDefault();
  ghostPos = getPos(e);
}
function onTap(e) {
  e.preventDefault&&e.preventDefault();
  if (phase!=='place') return;
  const pos=getPos(e);
  if (pos.y<50+MAG_R||pos.y>canvas.height-50) return;
  for (const m of magnets) {
    if (Math.hypot(pos.x-m.x,pos.y-m.y)<MAG_R*2.5) { showToast('放置太近了！'); return; }
  }
  if (magnets.length>=levelCfg.balls) { showToast('磁铁已放满！'); return; }
  magnets.push({x:pos.x,y:pos.y,hitTime:0,phase:Math.random()*Math.PI*2});
  const rem=levelCfg.balls-magnets.length;
  document.getElementById('ballsVal').textContent=rem;
  document.getElementById('hint').textContent=
    rem>0?`点击放置磁铁 (剩余 ${rem} 个) · 放置完成后按【开始坠落】`:'磁铁已全部放置 · 点击【开始坠落】';
  spawnSparks(pos.x,pos.y);
}

function showToast(msg) {
  let t=document.getElementById('toast');
  if(!t){ t=document.createElement('div');t.id='toast';document.body.appendChild(t); }
  t.textContent=msg; t.style.opacity='1';
  clearTimeout(t._t);
  t._t=setTimeout(()=>{t.style.opacity='0';},1800);
}

render();
</script>
